# Customer PostgreSQL (READ ONLY)
CUSTOMER_DATABASE_URL=postgresql://readonly:password@db.example.com:5432/myapp

# GrowthClaw internal PostgreSQL (can be same DB with different schema, or separate)
GROWTHCLAW_DATABASE_URL=postgresql://growthclaw:password@db.example.com:5432/myapp

# LLM providers (at least one required)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15550123456

# GrowthClaw settings
GROWTHCLAW_BUSINESS_NAME=
GROWTHCLAW_BUSINESS_DESCRIPTION=
GROWTHCLAW_CARD_LINK_URL=https://app.example.com
GROWTHCLAW_MAX_FIRES_PER_TRIGGER=3
GROWTHCLAW_COOLDOWN_HOURS=24
GROWTHCLAW_QUIET_HOURS_START=21
GROWTHCLAW_QUIET_HOURS_END=8
GROWTHCLAW_DRY_RUN=true
GROWTHCLAW_SAMPLE_ROWS=500
