# Customer PostgreSQL (READ ONLY)
CUSTOMER_DATABASE_URL=postgresql://readonly:password@db.example.com:5432/myapp

# GrowthClaw internal PostgreSQL (can be same DB with different schema, or separate)
GROWTHCLAW_DATABASE_URL=postgresql://growthclaw:password@db.example.com:5432/myapp

# LLM providers (at least one required)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_URL=                                  # Local NIM: http://localhost:8000/v1 (leave blank for cloud)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15550123456

# Email provider ("resend" or "sendgrid")
GROWTHCLAW_EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxx
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx       # Use instead if email_provider=sendgrid
GROWTHCLAW_FROM_EMAIL=hello@yourbusiness.com
GROWTHCLAW_FROM_NAME=GrowthClaw

# GrowthClaw settings
GROWTHCLAW_BUSINESS_NAME=
GROWTHCLAW_BUSINESS_DESCRIPTION=
GROWTHCLAW_CTA_URL=https://app.example.com
GROWTHCLAW_MAX_FIRES_PER_TRIGGER=3
GROWTHCLAW_COOLDOWN_HOURS=24
GROWTHCLAW_QUIET_HOURS_START=21
GROWTHCLAW_QUIET_HOURS_END=8
GROWTHCLAW_DRY_RUN=true
GROWTHCLAW_SAMPLE_ROWS=500

# Global frequency caps (cross-trigger)
GROWTHCLAW_MAX_SMS_PER_DAY=2
GROWTHCLAW_MAX_SMS_PER_WEEK=5
GROWTHCLAW_MAX_EMAIL_PER_DAY=2
GROWTHCLAW_MAX_EMAIL_PER_WEEK=7

# Memory system (for AutoResearch agent memory)
OPENAI_API_KEY=sk-xxxxxxxxxxxx              # For embeddings (text-embedding-3-small)
GROWTHCLAW_MEMORY_PATH=~/.growthclaw/memory  # LanceDB storage path
